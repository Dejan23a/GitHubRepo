pipeline {
    agent any

    stages {
        stage('Confirm test run') {
            steps {
                script {
                    def response = input message: 'Continue with python_test1?',
                    parameters: [choice(
                        choices: 'Yes\nNo',
                        description: 'Choose Yes to continue or No to stop',
                        name: 'continue_test'
                    )]

                    if (response != 'Yes') {
                        error('Test execution stopped by user.')
                    }
                }
            }
        }

        stage('Run Python test') {
            steps {
                bat 'py --version'
                bat 'py jenkins_test1.py'
            }
        }
    }
}